# Copy to ".env" for local dev (not committed). On Render, set these in the dashboard.

# On Render: use 3.12.x (e.g. 3.12.7). Avoid 3.14 unless you know Django supports it there.
# PYTHON_VERSION=3.12.7

DJANGO_DEBUG=True
DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=
DJANGO_CSRF_TRUSTED_ORIGINS=

EMAIL_HOST_USER=your@gmail.com
EMAIL_HOST_PASSWORD=your-gmail-app-password
